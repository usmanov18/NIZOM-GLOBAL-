# Fastlane configuration for NIZOM GLOBAL

default_platform(:android)

platform :android do
  desc "Run tests"
  lane :test do
    flutter(
      command: "test",
    )
  end

  desc "Build Android APK"
  lane :build_apk do
    flutter(
      command: "build apk --release",
    )
  end

  desc "Build Android App Bundle"
  lane :build_appbundle do
    flutter(
      command: "build appbundle --release",
    )
  end

  desc "Deploy to Firebase App Distribution"
  lane :deploy_firebase do
    build_appbundle
    
    firebase_app_distribution(
      app: ENV["FIREBASE_ANDROID_APP_ID"],
      groups: "testers",
      release_notes: "NIZOM GLOBAL v#{get_version_name}",
    )
  end

  desc "Deploy to Google Play"
  lane :deploy_play_store do
    build_appbundle
    
    upload_to_play_store(
      track: "internal",
      aab: "../build/app/outputs/bundle/release/app-release.aab",
    )
  end
end

platform :ios do
  desc "Build iOS"
  lane :build_ios do
    flutter(
      command: "build ios --release --no-codesign",
    )
  end

  desc "Deploy to TestFlight"
  lane :deploy_testflight do
    build_ios
    
    upload_to_testflight(
      ipa: "../build/ios/ipa/nizom_global.ipa",
    )
  end
end
